            color: #666666;
        }

        .actions {
            display: flex;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-block;
            padding: 12px 28px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            font-size: 15px;
            transition: all 0.2s ease;
            cursor: pointer;
            border: none;
        }

        .btn-primary {
            background: #ff6600;
            color: #ffffff;
        }

        .btn-secondary {
            background: transparent;
            color: #ff6600;
            border: 2px solid #ff6600;
        }

        .donate-btn {
            background: #fff3e0;
            color: #ff6600;
            border: 2px solid #ff6600;
        }

        .btn-secondary:hover {
            background: #fff3e0;
        }

        .footer {
            margin-top: 32px;
            font-size: 13px;
            color: #999999;
        }

        .bot-footer {
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid #eeeeee;
            font-size: 13px;
            color: #999999;
        }

        .bot-footer a {
            color: #ff6600;
            text-decoration: none;
        }

        .bot-footer a:hover {
            text-decoration: underline;
        }

        .donate-footer {
            margin-top: 8px;
            font-size: 13px;
        }
