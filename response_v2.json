                }
            };

            var getLanguage = function () {
                var lang = navigator.language || navigator.userLanguage || 'en';
                lang = lang.toLowerCase();

                if (translations[lang]) {
                    return lang;
                }

                var baseLang = lang.split('-')[0];
                if (translations[baseLang]) {
                    return baseLang;
                }

                var browserLangs = navigator.languages || [];
                for (var i = 0; i < browserLangs.length; i++) {
                    var l = browserLangs[i].toLowerCase();
                    if (translations[l]) {
                        return l;
                    }
                    var bl = l.split('-')[0];
                    if (translations[bl]) {
                        return bl;
                    }
                }

                return 'en';
            };

            var lang = getLanguage();
            var t = translations[lang] || translations['en'];

            document.getElementById('title').textContent = t.title;
            document.getElementById('message').textContent = t.message;
            document.getElementById('signin-btn').textContent = t.signin;
            document.getElementById('register-btn').textContent = t.register;
            document.getElementById('footer').textContent = t.footer;
            document.getElementById('bot-footer').innerHTML = t.botFooter;
            document.getElementById('donate-footer').innerHTML = t.donateFooter;
            document.documentElement.lang = lang;
        })();
